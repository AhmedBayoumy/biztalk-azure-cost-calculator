# === AI Parsing ===
# Option A: GitHub Token (recommended — works if you have GitHub CLI installed)
# Run: gh auth login  →  GH_TOKEN is set automatically
GH_TOKEN=your_github_personal_access_token

# Option B: OpenAI-compatible key
OPENAI_API_KEY=sk-...

# === GitHub OAuth (for saving estimates + automatic AI auth) ===
# Create at: https://github.com/settings/developers → OAuth Apps → New
# Homepage URL: http://localhost:3420
# Callback URL: http://localhost:3420/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# NextAuth secret — REQUIRED in production. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# IMPORTANT: Update NEXTAUTH_URL for production deployment!
# Local dev:  http://localhost:3420
# Vercel:     https://your-app.vercel.app
# Custom:     https://yourdomain.com
NEXTAUTH_URL=http://localhost:3420

# === Database ===
# ⚠️  VERCEL WARNING: better-sqlite3 (SQLite) does NOT work on Vercel serverless.
# Vercel has a read-only filesystem and no native module support for better-sqlite3.
# For Vercel deployment, migrate to one of:
#   - Turso (serverless SQLite):  https://turso.tech  — drop-in replacement
#   - Vercel Postgres:            https://vercel.com/storage/postgres
#   - Supabase:                   https://supabase.com
# For self-hosted (VPS/Docker), SQLite works fine — no changes needed.
